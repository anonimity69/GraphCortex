NEO4J_URI=neo4j://127.0.0.1:7688
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=cortex_secure_graph_99!

# ─── Embedding Model Configuration ─────────────────────────────────────────
# Supported: any HuggingFace sentence-transformers model
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# Device: mps (Mac GPU), cuda (Win/Linux GPU), cpu (Standard)
# Note: Docker defaults to 'cpu' for stability; local runs can use 'mps'.
EMBEDDING_DEVICE=cpu

# ─── Retrieval Engine (Spreading Activation) ───────────────────────────────
# Maximum BFS hop depth from each anchor node
RETRIEVAL_MAX_DEPTH=3
# Minimum activation energy for a node to survive Lateral Inhibition
RETRIEVAL_CUTOFF_THRESHOLD=0.2

# ─── Lateral Inhibition (Energy Decay Formula) ─────────────────────────────
# Starting energy for anchor nodes (maximum = 1.0)
INHIBITION_INITIAL_ENERGY=1.0
# Distance decay rate (higher = faster drop-off with hops)
INHIBITION_DISTANCE_PENALTY=0.5
# Hub penalty rate (higher = harsher suppression of high-degree nodes)
INHIBITION_DEGREE_PENALTY=0.1

# ─── Semantic Vector Fallback ───────────────────────────────────────────────
# Minimum cosine similarity to accept a vector match as a valid anchor
SEMANTIC_SIMILARITY_THRESHOLD=0.65
# Max anchors returned by semantic vector search
SEMANTIC_ANCHOR_LIMIT=2
# Max anchors returned by lexical string search
LEXICAL_ANCHOR_LIMIT=5

# ─── Property Sharding ─────────────────────────────────────────────────────
# Storage mode: "local" (inline on graph) or "s3" (external offload)
SHARDING_MODE=local
# S3 bucket prefix (only used when SHARDING_MODE=s3)
SHARDING_S3_BUCKET=s3://ns-dmg-shard

# ─── Logging ────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─── LLM Orchestration (Phase 3 & 4) ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ─── Ray Configuration ──────────────────────────────────────────────────────
RAY_ADDRESS=auto
